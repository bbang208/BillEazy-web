# Claude API 키 — 이 파일을 .env 로 복사해 채우세요. (이 키는 server 에만 보관, 프론트 노출 금지)
ANTHROPIC_API_KEY=

# 서버 포트
PORT=8080

# CORS 허용 오리진 (콤마로 여러 개)
ALLOWED_ORIGIN=http://localhost:3000

# 크레딧 없이 UI 전체 플로우 테스트용 목(mock) 모드.
# 1 이면 /api/extract 가 실제 Claude 호출 대신 샘플 영수증 데이터를 반환.
# 크레딧 충전 후 실제 인식을 쓰려면 0 으로 바꾸거나 이 줄을 지우세요.
MOCK_EXTRACT=0
