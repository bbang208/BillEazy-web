# Claude API 키 — 이 파일을 .env 로 복사해 채우세요. (이 키는 server 에만 보관, 프론트 노출 금지)
ANTHROPIC_API_KEY=

# 서버 포트
PORT=8080

# CORS 허용 오리진 (콤마로 여러 개)
ALLOWED_ORIGIN=http://localhost:3000

# 크레딧 없이 UI 전체 플로우 테스트용 목(mock) 모드.
# 1 이면 /api/extract 가 실제 Claude 호출 대신 샘플 영수증 데이터를 반환.
# 크레딧 충전 후 실제 인식을 쓰려면 0 으로 바꾸거나 이 줄을 지우세요.
MOCK_EXTRACT=0

# ── 네이버 지도(주유대 출발·목적지 검색 + 경로 거리) ──
# 장소(POI) 검색: 네이버 개발자센터(developers.naver.com) 애플리케이션의 검색 API.
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
# 경로/거리: 네이버 클라우드 플랫폼(NCP) Maps Directions 5. VPC 환경, Maps 상품 이용신청 필요.
NCP_MAPS_KEY_ID=
NCP_MAPS_KEY=
# 키 없이 지도 기능 UI/플로우 테스트용 목 모드. 1 이면 샘플 장소·거리를 반환.
MOCK_MAPS=1
